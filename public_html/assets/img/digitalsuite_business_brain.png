      <feColorMatrix type="matrix" values="1 0 0 0 0  0 0.2 0 0 0  0 0 0.2 0 0  0 0 0 0.8 0" />
      <feBlend in="SourceGraphic" in2="blur" mode="screen" />
    </filter>
  </defs>
  <rect width="900" height="900" fill="#070709" />
  <circle cx="450" cy="360" r="320" fill="url(#glow)" />
