DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/football
LOG_LEVEL=INFO
APP_NAME=Football Predictor API
APP_ENV=development
FOOTBALL_DATA_PROVIDER=mock
FOOTBALL_DATA_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_TIMEOUT_SECONDS=20
FOOTBALL_DATA_LEAGUE_IDS=39
FOOTBALL_DATA_SEASONS=2024
FOOTBALL_DATA_MAX_RETRIES=3
FOOTBALL_DATA_MAX_BACKOFF_SECONDS=8
ARTIFACT_PATH=./artifacts/baseline_model.json
ACTIVE_MODEL_NAME=ridge_poisson_v1_5
CHALLENGER_MODEL_NAMES=ridge_poisson_v1_5,ridge_poisson_v1_5_weighted
ALLOW_AUTO_TRAIN_ON_PREDICT=true
